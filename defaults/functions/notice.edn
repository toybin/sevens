{:name "notice"
 :description "Surface patterns, gaps, tensions, and implicit assumptions in a node and its neighborhood"
 :context
 [{:path ["node/parent"]
   :with ["node/content"]
   :as "parent"}
  {:path ["node/parent" "node/parent~"]
   :exclude-self true
   :with ["node/content"]
   :as "siblings"}
  {:path ["node/parent~"]
   :with ["node/content"]
   :as "children"}]
 :input "node"
 :output "text"}
