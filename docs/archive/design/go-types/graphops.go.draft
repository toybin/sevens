// Package graphops is Layer 2: predicate metadata and graph-conscious
// operations over a triple store.
//
// This package knows about predicates (functional vs. relational,
// inverses, symmetry) and path composition, but nothing about sevens,
// PKM, or any specific predicate vocabulary.
//
// Reusable outside sevens -- a Haskell port or a different domain
// would use the same abstractions.
package graphops

import (
	"context"

	"sevens/internal/triple"
)

// Multiplicity describes how many objects a predicate allows per subject.
type Multiplicity int

const (
	Relational Multiplicity = iota // zero or more (set-valued)
	Functional                     // exactly one (or zero if optional)
)

// PredicateSpec declares the properties of a predicate that graph
// operations need to behave correctly.
//
// Design note: this is Layer 2 state from the concept doc. The graph
// (Layer 1) doesn't carry this metadata. Layer 2 uses it to provide
// correct operations (e.g., Set only works on Functional predicates).
type PredicateSpec struct {
	Name         string
	Multiplicity Multiplicity
	Inverse      string // name used when traversing backward; empty if none
	Symmetric    bool   // if true, (A,r,B) implies (B,r,A)
	Transitive   bool   // if true, reachability queries can follow chains
}

// Graph wraps a triple.Store with predicate metadata and provides
// higher-level graph operations.
//
// Go idiom: Graph depends on triple.Store (a concrete type from
// the layer below). It doesn't depend on anything above. This is
// the clean dependency direction: Layer 2 -> Layer 1.
type Graph struct {
	store *triple.Store
	specs map[string]*PredicateSpec
}

// New creates a Graph backed by the given triple store.
func New(store *triple.Store) *Graph {
	return &Graph{
		store: store,
		specs: make(map[string]*PredicateSpec),
	}
}

// RegisterPredicate declares a predicate's metadata. Call this during
// initialization to set up the vocabulary before performing operations.
//
// Layer 3 (kb) calls this to register node/parent, node/content, etc.
// Layer 4 (user-defined) could call it for custom predicates.
func (g *Graph) RegisterPredicate(spec PredicateSpec) {
	g.specs[spec.Name] = &spec
}

