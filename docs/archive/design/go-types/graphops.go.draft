// --- Path composition ---

// PathStep is one hop in a composed path. Forward follows
// (subject, predicate) -> objects. Inverse follows
// (predicate, object) -> subjects (i.e., traverse the arrow backward).
type PathStep struct {
	Predicate string
	Inverse   bool
}

// ParsePath converts a string path like ["node/parent", "node/parent~"]
// into typed PathSteps. The ~ suffix means inverse traversal.
//
// This is the operation from apply/patheval.go, generalized.
// It doesn't know what "node/parent" means -- it just knows that
// ~ means inverse.
func ParsePath(predicates []string) []PathStep {
	steps := make([]PathStep, len(predicates))
	for i, p := range predicates {
		if len(p) > 0 && p[len(p)-1] == '~' {
			steps[i] = PathStep{Predicate: p[:len(p)-1], Inverse: true}
		} else {
			steps[i] = PathStep{Predicate: p, Inverse: false}
		}
	}
	return steps
}

// Compose walks a sequence of predicate hops from a starting subject,
// returning all subjects reachable at the end of the path.
//
// This is arrow composition: follow predicate A, then predicate B,
// then predicate C. Each step either goes forward (subject->object)
// or inverse (object->subject).
//
// The current code does this hop-by-hop in apply/patheval.go with
// individual GetObjects/GetSubjects calls. This centralizes it.
func (g *Graph) Compose(ctx context.Context, start string, path []PathStep) ([]string, error) {
	current := []string{start}
	for _, step := range path {
		var next []string
		for _, subj := range current {
			var results []string
			var err error
			if step.Inverse {
				results, err = g.store.ByPredicateObject(ctx, step.Predicate, subj)
			} else {
				results, err = g.store.BySubjectPredicate(ctx, subj, step.Predicate)
			}
			if err != nil {
				return nil, err
			}
			next = append(next, results...)
		}
		current = deduplicate(next)
	}
	return current, nil
}

// Reachable returns all subjects reachable from start by recursively
// following a predicate. Requires the predicate to be registered as
// transitive, or just does the recursive walk regardless.
func (g *Graph) Reachable(ctx context.Context, start string, predicate string, inverse bool) ([]string, error) {
	panic("TODO")
}

