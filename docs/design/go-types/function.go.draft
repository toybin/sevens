// ============================================================
// Context resolution
// ============================================================

// ResolvedContext holds all resolved inputs for a step, ready for
// prompt rendering.
type ResolvedContext struct {
	Target      kb.WalkContext
	Parent      *string
	Siblings    []ResolvedNode
	Children    []ResolvedNode
	History     []kb.LogEntry
	PriorOutput string // output from previous step
	Instruction string // ad-hoc instruction via {{instruction}}
}

// ResolvedNode is a fetched node's content for template rendering.
type ResolvedNode struct {
	Title   string
	Content string
	Role    string
}

// resolveContext gathers graph context for a step based on its
