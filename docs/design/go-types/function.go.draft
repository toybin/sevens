// ============================================================
// Pipeline persistence
// ============================================================

// PipelineStore handles reading and writing pipeline state to the
// triple store. Pipeline state is stored as triples with pipeline/*
// predicates.
//
// This is separate from Executor because persistence is orthogonal
// to execution. You could run a pipeline entirely in memory (tests)
// or persist every transition (production).
type PipelineStore struct {
	kb KnowledgeBase
}

// Save persists a pipeline's current state as triples.
