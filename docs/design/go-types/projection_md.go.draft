// --- Markdown-specific types ---

// ParsedNode is a fully parsed markdown file.
// Equivalent to graph.ParsedNode in the current code.
type ParsedNode struct {
	Title        string
	Parent       *string
	FilePath     string
	Content      string
	CrossRefs    []string
	SiblingRole  string
	IncludeGroup bool
	Blocks       []ParsedBlock
}

// ParsedBlock is a structural unit within a node's body.
// Equivalent to graph.ParsedBlock in the current code.
type ParsedBlock struct {
	Path         string
	Kind         string // "heading", "paragraph", "list-item", "task"
	Text         string
	Level        int
	Signifier    string
	Tags         []string
	HeadingChain []string
	AnchorHashes []string
	TextHash     uint64
	ScopeHash    uint64
	TagHash      uint64
	AnchorCount  uint8
	Anchors      [4]uint64
}

// --- Markdown-specific operations ---

