// --- Block identity tracking ---
// The fuzzy matching machinery: shingle anchors, text hashes,
// scored candidate resolution. This is entirely format-specific --
// a webapp projection wouldn't need any of this.

// DiffBlocks compares two block lists and classifies changes.
func DiffBlocks(old, new []ParsedBlock) *BlockDiff {
	panic("TODO")
}

// BlockDiff classifies how blocks changed between two parses.
type BlockDiff struct {
	Unchanged    []BlockChange
	Edited       []BlockChange
	ScopeChanged []BlockChange
	Reordered    []BlockChange
	Inserted     []string
	Deleted      []string
}

// BlockChange is a matched pair of old/new block paths.
type BlockChange struct {
	OldPath string
	NewPath string
}

