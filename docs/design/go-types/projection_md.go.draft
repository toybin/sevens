// Package md implements the Projection contract for Markdown files.
//
// This package owns:
// - Markdown parsing (file -> parsed nodes -> triples)
// - Markdown rendering (triples -> file content)
// - Block identity tracking (fuzzy matching across edits)
// - Frontmatter handling
// - Git operations (version control of projected files)
// - File watching (future: detect external edits)
// - DSL extensions (future: typed property lists)
//
// Conceptually this is everything in the current internal/graph that
// relates to files + sync, plus git.go from internal/apply.
package md

import (
	"context"
	"database/sql"

	"sevens/internal/kb"
	"sevens/internal/projection"
)

// MarkdownProjection implements projection.Projection for markdown files.
type MarkdownProjection struct {
	kb   *kb.KB
	// db kept for now since sync does bulk triple operations
	// that may bypass kb's per-node methods for performance.
	db   *sql.DB
}

// New creates a markdown projection backed by the given KB.
func New(kb *kb.KB, db *sql.DB) *MarkdownProjection {
	return &MarkdownProjection{kb: kb, db: db}
}

